# Override global .gitignore_global which ignores build/ entirely —
# this project ships the rendered PDF as a versioned artefact.
!build/
!build/build.py
!build/octatrack-mk1-manual.pdf
!build/.gitkeep

# Build artefacts that should stay local
build/manual.html
build/preview-*.png
build/preview*.pdf
build/draft*.pdf

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editors
.vscode/
.idea/
*.swp
.DS_Store

# Local notes / drafts
TODO.md
NOTES.md
drafts/

# Secrets and per-project tooling (never commit)
.secrets
.env
.env.*
.mcp.json
node_modules/
